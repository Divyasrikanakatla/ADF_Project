{
    "name": "factbookingold",
    "properties": {
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "dataset": {
                        "referenceName": "factbookingsilversinktable",
                        "type": "DatasetReference"
                    },
                    "name": "factsilvertable"
                },
                {
                    "dataset": {
                        "referenceName": "silverdimpassengertable",
                        "type": "DatasetReference"
                    },
                    "name": "dimpassengersilvertable"
                },
                {
                    "dataset": {
                        "referenceName": "DimFlightsql",
                        "type": "DatasetReference"
                    },
                    "name": "dimflightsilversource"
                },
                {
                    "dataset": {
                        "referenceName": "silverDimairport",
                        "type": "DatasetReference"
                    },
                    "name": "dimairportsilver"
                }
            ],
            "sinks": [
                {
                    "dataset": {
                        "referenceName": "AzureSqlTable5",
                        "type": "DatasetReference"
                    },
                    "name": "FactBookingGold"
                }
            ],
            "transformations": [
                {
                    "name": "select1dimpassengercoloumns"
                },
                {
                    "name": "lookupdimpassenger"
                },
                {
                    "name": "lookfordimflight"
                },
                {
                    "name": "lookupdimflight"
                },
                {
                    "name": "derivedColumn1"
                },
                {
                    "name": "selectcolumnsforgoldtable"
                },
                {
                    "name": "selectcoloumnfororigiairportname"
                },
                {
                    "name": "selectcolumnfororiginaairportname"
                }
            ],
            "scriptLines": [
                "source(output(",
                "          booking_id as integer,",
                "          passenger_id as integer,",
                "          flight_id as integer,",
                "          airline_id as integer,",
                "          origin_airport_id as integer,",
                "          destination_airport_id as integer,",
                "          booking_date as date,",
                "          ticket_cost as decimal(10,2),",
                "          flight_duration_mins as integer,",
                "          checkin_status as string,",
                "          TicketCategory as string,",
                "          DurationBucket as string,",
                "          CheckingStatus as string,",
                "          CheckingFlag as integer,",
                "          dimflight_flight_id as integer,",
                "          Depature_timebucket as string,",
                "          Arrival_timebucket as string,",
                "          DimFlight_SK as long,",
                "          dimpassenger_passenger_id as integer,",
                "          Age_Group as string,",
                "          DimPassenger_SK as long,",
                "          dimairline_Airline_ID as short,",
                "          Airline_Name as string,",
                "          DimAirline_SK as long,",
                "          DimAirport_Airport_ID as short,",
                "          OriginAirport_SK as long,",
                "          DestinationAirport_SK as long",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> factsilvertable",
                "source(output(",
                "          passenger_id as integer,",
                "          full_name as string,",
                "          gender as string,",
                "          age as integer,",
                "          country as string,",
                "          First_Name as string,",
                "          Last_Name as string,",
                "          Age_Group as string,",
                "          DimPassenger_SK as long,",
                "          DimPassengerCreateDate as timestamp,",
                "          Source as string",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> dimpassengersilvertable",
                "source(output(",
                "          flight_id as short,",
                "          flight_number as string,",
                "          departure_time as string,",
                "          arrival_time as string,",
                "          FlightDuration as integer,",
                "          Depature_timebucket as string,",
                "          Arrival_timebucket as string,",
                "          DimFlight_SK as long",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> dimflightsilversource",
                "source(output(",
                "          Airport_ID as short,",
                "          Airport_Name as string,",
                "          city as string,",
                "          country as string,",
                "          AirportCode as string,",
                "          CityCountry as string,",
                "          DimAirport_SK as long",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     isolationLevel: 'READ_UNCOMMITTED',",
                "     format: 'table') ~> dimairportsilver",
                "dimpassengersilvertable select(mapColumn(",
                "          dimpassenger_gold_passenger_id = passenger_id,",
                "          First_Name,",
                "          Last_Name,",
                "          Age_Group",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> select1dimpassengercoloumns",
                "factsilvertable, select1dimpassengercoloumns lookup(passenger_id == dimpassenger_gold_passenger_id,",
                "     multiple: false,",
                "     pickup: 'any',",
                "     broadcast: 'auto')~> lookupdimpassenger",
                "dimflightsilversource select(mapColumn(",
                "          dimgold_flight_id = flight_id,",
                "          flight_number",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> lookfordimflight",
                "lookupdimpassenger, lookfordimflight lookup(flight_id == dimgold_flight_id,",
                "     multiple: false,",
                "     pickup: 'any',",
                "     broadcast: 'auto')~> lookupdimflight",
                "lookupdimflight derive(flight_duration_hours = round(flight_duration_mins/60,1)) ~> derivedColumn1",
                "derivedColumn1 select(mapColumn(",
                "          booking_id,",
                "          flight_id,",
                "          origin_airport_id,",
                "          booking_date,",
                "          Revenue = ticket_cost,",
                "          flight_duration_mins,",
                "          checkin_status,",
                "          TicketCategory,",
                "          DurationBucket,",
                "          CheckingStatus,",
                "          CheckingFlag,",
                "          Depature_timebucket,",
                "          Arrival_timebucket,",
                "          DimFlight_SK,",
                "          dimpassenger_passenger_id,",
                "          DimPassenger_SK,",
                "          Airline_Name,",
                "          DimAirline_SK,",
                "          OriginAirport_SK,",
                "          DestinationAirport_SK,",
                "          First_Name,",
                "          Last_Name,",
                "          flight_number,",
                "          flight_duration_hours",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> selectcolumnsforgoldtable",
                "selectcolumnsforgoldtable, selectcolumnfororiginaairportname lookup(toInteger(origin_airport_id) == toInteger(Airport_ID),",
                "     multiple: false,",
                "     pickup: 'any',",
                "     broadcast: 'auto')~> selectcoloumnfororigiairportname",
                "dimairportsilver select(mapColumn(",
                "          Airport_ID,",
                "          Origin_airport_name = Airport_Name",
                "     ),",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true) ~> selectcolumnfororiginaairportname",
                "selectcoloumnfororigiairportname sink(allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     deletable:false,",
                "     insertable:true,",
                "     updateable:false,",
                "     upsertable:false,",
                "     format: 'table',",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true,",
                "     errorHandlingOption: 'stopOnFirstError') ~> FactBookingGold"
            ]
        }
    }
}
