                            "source": {
                                "name": "airline_id",
                                "type": "String",
                                "physicalType": "String"
                            },
                            "sink": {
                                "name": "airline_id",
                                "type": "String",
                                "physicalType": "String"
                            }
                        },
                        {
                            "source": {
                                "name": "airline_name",
                                "type": "String",
                                "physicalType": "String"
                            },
                            "sink": {
                                "name": "airline_name",
                                "type": "String",
                                "physicalType": "String"
                            }
                        },
                        {
                            "source": {
                                "name": "country",
                                "type": "String",
                                "physicalType": "String"
                            },
                            "sink": {
                                "name": "country",
                                "type": "String",
                                "physicalType": "String"
                            }
                        }
                    ],
                    "typeConversion": true,
                    "typeConversionSettings": {
                        "allowDataTruncation": true,
                        "treatBooleanAsNumber": false
                    }
                }
            }
        },
